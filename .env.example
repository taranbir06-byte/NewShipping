# ═══════════════════════════════════════════════════════
#  KAHLON SHIPYARD — Environment Variables
#  Copy this file to .env and fill in your values
#  DO NOT commit .env to git
# ═══════════════════════════════════════════════════════

# Server
PORT=3001
NODE_ENV=development

# JWT Secret — use any long random string
JWT_SECRET=change_this_to_a_long_random_secret_string_minimum_32_chars

# Database path (leave blank for default, set for Railway volume)
# DB_PATH=/app/data/kahlon.db

# Razorpay — get from dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=

# Cashfree — get from merchant.cashfree.com → Developers → API Keys
CASHFREE_APP_ID=XXXXXXXXXXXXXXXX
CASHFREE_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CASHFREE_ENV=TEST

# App URL (set automatically on Railway, leave blank locally)
# APP_URL=https://your-app.up.railway.app
